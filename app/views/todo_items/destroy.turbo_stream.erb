<%= turbo_stream.remove dom_id(@todo_item) %>

<%# Show the "no items" message again once the last item is gone. %>
<%= turbo_stream.replace "todo_items_empty" do %>
  <%= render "todo_items/empty", todo_items: @todo_items %>
<% end %>

<%= turbo_stream.replace "todo_items_stats" do %>
  <%= render "todo_items/stats", todo_list: @todo_list, items: @todo_items %>
<% end %>
