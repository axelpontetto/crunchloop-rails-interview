<%= turbo_stream.append "todo_items" do %>
  <%= render "todo_items/todo_item", todo_item: @todo_item, todo_list: @todo_list %>
<% end %>

<%= turbo_stream.replace "new_todo_item" do %>
  <%= turbo_frame_tag "new_todo_item" do %>
    <%= render "todo_items/form", todo_list: @todo_list, todo_item: TodoItem.new(todo_list: @todo_list) %>
  <% end %>
<% end %>

<%= turbo_stream.replace "todo_items_empty" do %>
  <%= render "todo_items/empty", todo_items: @todo_list.todo_items.reload %>
<% end %>
