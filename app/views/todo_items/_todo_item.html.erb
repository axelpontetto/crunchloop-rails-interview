<%= turbo_frame_tag dom_id(todo_item) do %>
  <div class="group flex items-center gap-3 rounded-lg border border-slate-200 px-3 py-2 hover:bg-slate-50">
    <%= form_with model: [todo_list, todo_item], class: "flex items-center" do |form| %>
      <%= form.check_box :complete,
            id: dom_id(todo_item, :complete),
            onchange: "this.form.requestSubmit()",
            class: "h-5 w-5 cursor-pointer rounded border-slate-300 text-indigo-600 focus:ring-indigo-500" %>
    <% end %>

    <span class="flex-1 truncate <%= 'text-slate-400 line-through' if todo_item.complete %>">
      <%= todo_item.title %>
    </span>

    <%= link_to edit_todo_list_todo_item_path(todo_list, todo_item),
          class: "rounded p-1 text-slate-400 hover:bg-slate-200 hover:text-slate-700",
          title: "Edit" do %>
      <span aria-hidden="true">&#9998;</span>
    <% end %>

    <%= button_to [todo_list, todo_item],
          method: :delete,
          class: "rounded p-1 text-slate-400 hover:bg-red-100 hover:text-red-600",
          form: { data: { turbo_confirm: "Delete '#{todo_item.title}' item?" } },
          title: "Delete" do %>
      <span aria-hidden="true">&#10005;</span>
    <% end %>
  </div>
<% end %>
