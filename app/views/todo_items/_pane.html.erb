<% items = todo_list.todo_items %>
<div>
  <div class="flex items-center justify-between mb-4">
    <h2 class="text-lg font-semibold text-slate-900">Todo Items</h2>
    <span class="truncate text-sm text-slate-400"><%= todo_list.name %></span>
  </div>

  <div class="flex items-center gap-2 mb-4">
    <%= button_to "Check all",
          check_all_todo_list_todo_items_path(todo_list),
          method: :patch,
          class: "shrink-0 rounded-lg border border-slate-300 px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50 cursor-pointer" %>

    <div class="flex-1">
      <%= turbo_frame_tag "new_todo_item" do %>
        <%= render "todo_items/form", todo_list: todo_list, todo_item: TodoItem.new(todo_list: todo_list) %>
      <% end %>
    </div>
  </div>

  <div id="todo_items" class="flex flex-col gap-4">
    <%= render partial: "todo_items/todo_item", collection: items, locals: { todo_list: todo_list } %>
    <%= render "todo_items/empty", todo_items: items %>
  </div>
</div>
